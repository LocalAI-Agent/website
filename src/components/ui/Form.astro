---
import type { Form as Props } from '~/types';
import Button from '~/components/ui/Button.astro';

const {
  inputs,
  textarea,
  disclaimer,
  button = 'Contact us',
  description = '',
  formAction = import.meta.env.FORMSPREE_ENDPOINT,
} = Astro.props;
---

<form method="POST" action={formAction} class="space-y-6" aria-label="Contact form">
  {
    inputs &&
      inputs.map(
        ({ type = 'text', name, label = '', autocomplete = 'on', placeholder = '' }) =>
          name && (
            <div class="mb-6">
              {label && (
                <label for={name} class="block text-sm font-medium mb-2 text-charcoal dark:text-white">
                  {label}
                </label>
              )}
              <input
                type={type}
                name={name}
                id={name}
                autocomplete={autocomplete}
                placeholder={placeholder}
                aria-label={label || name}
                required={type === 'email'}
                class="py-3 px-4 block w-full text-md rounded-lg border border-border bg-white/50 dark:bg-gray-800/50 backdrop-blur-sm focus:ring-2 focus:ring-klein dark:focus:ring-electric-cyan focus:border-transparent transition-all duration-300 text-charcoal dark:text-white placeholder-gray-400 dark:placeholder-gray-500"
                style="border-radius: 8px;"
              />
            </div>
          )
      )
  }

  {
    textarea && (
      <div class="mb-6">
        <label for="textarea" class="block text-sm font-medium mb-2 text-charcoal dark:text-white">
          {textarea.label}
        </label>
        <textarea
          id="textarea"
          name={textarea.name ? textarea.name : 'message'}
          rows={textarea.rows ? textarea.rows : 4}
          placeholder={textarea.placeholder}
          aria-label={textarea.label || 'Message'}
          class="py-3 px-4 block w-full text-md rounded-lg border border-border bg-white/50 dark:bg-gray-800/50 backdrop-blur-sm focus:ring-2 focus:ring-klein dark:focus:ring-electric-cyan focus:border-transparent transition-all duration-300 text-charcoal dark:text-white placeholder-gray-400 dark:placeholder-gray-500 resize-none"
          style="border-radius: 8px;"
        />
      </div>
    )
  }

  {
    disclaimer && (
      <div class="mt-3 flex items-start">
        <div class="flex mt-0.5">
          <input
            id="disclaimer"
            name="disclaimer"
            type="checkbox"
            required
            aria-describedby="disclaimer-label"
            class="cursor-pointer mt-1 py-3 px-4 block w-auto text-md rounded-lg border border-border bg-white/50 dark:bg-gray-800/50 backdrop-blur-sm focus:ring-2 focus:ring-klein dark:focus:ring-electric-cyan transition-all duration-300"
            style="border-radius: 8px;"
          />
        </div>
        <div class="ml-3">
          <label
            for="disclaimer"
            id="disclaimer-label"
            class="cursor-pointer select-none text-sm text-secondary dark:text-gray-400"
          >
            {disclaimer.label}
          </label>
        </div>
      </div>
    )
  }

  {
    button && (
      <div class="mt-10 grid">
        <Button variant="primary" type="submit" aria-label="Submit contact form">
          {button}
        </Button>
      </div>
    )
  }

  {
    description && (
      <div class="mt-6 text-center">
        <p class="text-sm text-secondary dark:text-gray-400">{description}</p>
      </div>
    )
  }
</form>
