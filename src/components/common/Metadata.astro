---
import merge from 'lodash.merge';
import { AstroSeo } from '@astrolib/seo';

import type { Props as AstroSeoProps } from '@astrolib/seo';

import { SITE, METADATA, I18N } from 'astrowind:config';
import type { MetaData } from '~/types';
import { getCanonical } from '~/utils/permalinks';

import { adaptOpenGraphImages, findImage } from '~/utils/images';

export interface Props extends MetaData {
  dontUseTitleTemplate?: boolean;
}

const {
  title,
  ignoreTitleTemplate = false,
  canonical = String(getCanonical(String(Astro.url.pathname))),
  robots = {},
  description,
  openGraph = {},
  twitter = {},
} = Astro.props;

// Default Twitter/OpenGraph image - use Astro's processed icon
const defaultImage = getCanonical('/_astro/icon.webp');

// Helper function to adapt Twitter card image and return the resolved image URL
async function resolveTwitterImage(twitterCard: typeof twitter = {}, site?: URL): Promise<string | undefined> {
  if (!site || !twitterCard?.image) return undefined;

  const resolvedImage = await findImage(twitterCard.image);
  if (!resolvedImage) return undefined;

  if (typeof resolvedImage === 'string') {
    // External URL or absolute path
    if (resolvedImage.startsWith('http://') || resolvedImage.startsWith('https://')) {
      return resolvedImage;
    }
    if (resolvedImage.startsWith('/')) {
      return new URL(resolvedImage, site).toString();
    }
    return resolvedImage;
  }

  if (typeof resolvedImage === 'object' && 'src' in resolvedImage) {
    // Astro ImageMetadata - create optimized URL
    return new URL(resolvedImage.src, site).toString();
  }

  return undefined;
}

// Helper function to adapt Twitter card (for other properties)
async function adaptTwitterCard(twitterCard: typeof twitter = {}, site?: URL) {
  if (!site) return twitterCard;

  const result = { ...twitterCard };

  // Handle 'image' property
  if (result.image) {
    try {
      result.image = new URL(result.image, site).toString();
    } catch {
      // Keep original if invalid URL
    }
  }

  // Remove 'image' property since we'll handle it separately
  delete result.image;

  return result;
}

const seoProps: AstroSeoProps = merge(
  {
    title: '',
    titleTemplate: '%s',
    canonical: canonical,
    noindex: true,
    nofollow: true,
    description: undefined,
    openGraph: {
      url: canonical,
      site_name: SITE?.name,
      images: [{ url: defaultImage, width: 1200, height: 630 }],
      locale: I18N?.language || 'en',
      type: 'website',
    },
    twitter: {
      cardType: 'summary_large_image',
      handle: SITE?.metadata?.twitter?.handle || '@localai67177',
      site: SITE?.metadata?.twitter?.site || '@localai67177',
    },
  },
  {
    title: METADATA?.title?.default,
    titleTemplate: METADATA?.title?.template,
    noindex: typeof METADATA?.robots?.index !== 'undefined' ? !METADATA.robots.index : undefined,
    nofollow: typeof METADATA?.robots?.follow !== 'undefined' ? !METADATA.robots.follow : undefined,
    description: METADATA?.description,
    openGraph: METADATA?.openGraph,
    twitter: {
      ...METADATA?.twitter,
      cardType: METADATA?.twitter?.cardType || 'summary_large_image',
    },
  },
  {
    title: title,
    titleTemplate: ignoreTitleTemplate ? '%s' : undefined,
    canonical: canonical,
    noindex: typeof robots?.index !== 'undefined' ? !robots.index : undefined,
    nofollow: typeof robots?.follow !== 'undefined' ? !robots.follow : undefined,
    description: description,
    openGraph: {
      url: canonical,
      ...openGraph,
    },
    twitter: {
      ...twitter,
      cardType: twitter?.cardType || 'summary_large_image',
      handle: twitter?.handle || SITE?.metadata?.twitter?.handle || '@localai67177',
      site: twitter?.site || SITE?.metadata?.twitter?.site || '@localai67177',
      image: twitter?.image || openGraph?.images?.[0]?.url || defaultImage,
    },
  }
);

// Resolve the Twitter card image URL
const twitterImageUrl = await resolveTwitterImage(seoProps.twitter, Astro.site);
---

<AstroSeo
  {...{
    ...seoProps,
    openGraph: await adaptOpenGraphImages(seoProps?.openGraph, Astro.site),
    twitter: await adaptTwitterCard(seoProps?.twitter, Astro.site),
  }}
/>
{twitterImageUrl && <meta name="twitter:image" content={twitterImageUrl} />}
