---
import { getCanonical } from '~/utils/permalinks';
import { SITE } from 'astrowind:config';

// Use the main hero image as Twitter card image for better visibility
// This image is already optimized and has proper dimensions (1200x675)
const defaultImage = getCanonical('/_astro/local-ai-agent-edge-server-hardware.EkZa4Ob2_ZKEcKq.jpg');
---

<meta charset="UTF-8" />
<meta name="viewport" content="width=device-width, initial-scale=1.0" />

<link rel="sitemap" href={getCanonical('/sitemap-index.xml')} />

<!-- Twitter Card Meta Tags -->
<meta name="twitter:card" content="summary_large_image" />
<meta name="twitter:site" content={SITE?.metadata?.twitter?.handle || '@localai67177'} />
<meta name="twitter:creator" content={SITE?.metadata?.twitter?.handle || '@localai67177'} />
<meta name="twitter:title" content={SITE?.metadata?.title?.default || 'LocalAI Agent'} />
<meta name="twitter:description" content={SITE?.metadata?.description || 'Enterprise AI Solutions'} />
<meta name="twitter:image" content={defaultImage} />
