---
import '@fontsource-variable/inter';

// 'DM Sans'
// Nunito
// Dosis
// Outfit
// Roboto
// Literata
// 'IBM Plex Sans'
// Karla
// Poppins
// 'Fira Sans'
// 'Libre Franklin'
// Inconsolata
// Raleway
// Oswald
// 'Space Grotesk'
// Urbanist
---

<style is:inline>
  :root {
    --aw-font-sans: 'Inter Variable';
    --aw-font-serif: 'Inter Variable';
    --aw-font-heading: 'Inter Variable';

    --aw-color-primary: rgb(1 97 239);
    --aw-color-secondary: rgb(1 84 207);
    --aw-color-accent: rgb(109 40 217);

    --aw-color-text-heading: rgb(0 0 0);
    --aw-color-text-default: rgb(16 16 16);
    --aw-color-text-muted: rgb(16 16 16 / 66%);

    /* Light Mode - "Clean Neural Lab" 
       Pure, professional, innovation-focused */
    --aw-color-bg-page: rgb(255 255 255);
    --aw-color-bg-page-dark: rgb(0 1 3);
    --aw-color-bg-card: rgb(255 255 255);
    --aw-color-bg-card-dark: rgb(0 1 3);
    --aw-color-bg-alt: rgb(247 249 252);
    --aw-color-bg-alt-dark: rgb(2 4 8);
    --aw-color-bg-gradient-start: rgb(255 255 255);
    --aw-color-bg-gradient-end: rgb(247 249 252);
    --aw-color-bg-gradient-start-dark: rgb(0 1 3);
    --aw-color-bg-gradient-end-dark: rgb(2 4 8);

    /* Glow Effects - Subtle neural network ambiance */
    --aw-glow-primary: radial-gradient(circle at 50% 0%, rgba(1, 97, 239, 0.06) 0%, transparent 60%);
    --aw-glow-accent: radial-gradient(circle at 75% 10%, rgba(109, 40, 217, 0.04) 0%, transparent 50%);
    --aw-glow-primary-dark: radial-gradient(circle at 50% 0%, rgba(1, 97, 239, 0.18) 0%, transparent 60%);
    --aw-glow-accent-dark: radial-gradient(circle at 75% 10%, rgba(109, 40, 217, 0.12) 0%, transparent 50%);

    /* Grid Pattern Colors */
    --aw-grid-dot-light: rgba(148, 163, 184, 0.15);
    --aw-grid-dot-dark: rgba(59, 130, 246, 0.08);

    ::selection {
      background-color: rgba(1, 97, 239, 0.15);
      color: rgb(1 97 239);
    }
  }

  .dark {
    --aw-font-sans: 'Inter Variable';
    --aw-font-serif: 'Inter Variable';
    --aw-font-heading: 'Inter Variable';

    --aw-color-primary: rgb(1 97 239);
    --aw-color-secondary: rgb(1 84 207);
    --aw-color-accent: rgb(109 40 217);

    --aw-color-text-heading: rgb(248 250 252);
    --aw-color-text-default: rgb(226 232 240);
    --aw-color-text-muted: rgb(226 232 240 / 60%);

    /* Dark Mode - "Deep Neural Space"
       Immersive, mysterious, cutting-edge */
    --aw-color-bg-page: rgb(0 1 3);
    --aw-color-bg-card: rgb(0 1 3);
    --aw-color-bg-card-dark: rgb(2 4 8);
    --aw-color-bg-alt: rgb(2 4 8);
    --aw-color-bg-alt-dark: rgb(0 1 3);
    --aw-color-bg-gradient-start: rgb(0 1 3);
    --aw-color-bg-gradient-end: rgb(2 4 8);

    ::selection {
      background-color: rgba(1, 97, 239, 0.35);
      color: rgb(96 165 250);
    }
  }
</style>
