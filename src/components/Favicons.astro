---
import icon_webp from '~/assets/favicons/icon.webp';
import icon_png from '~/assets/favicons/icon.png';
---

<link rel="shortcut icon" href="/favicon.ico" />
<link rel="icon" type="image/webp" href={icon_webp.src} />
<link rel="icon" type="image/png" sizes="32x32" href={icon_png.src} />
<link rel="apple-touch-icon" sizes="180x180" href={icon_webp.src} />
