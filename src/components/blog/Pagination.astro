---
import { Icon } from 'astro-icon/components';
import { getPermalink } from '~/utils/permalinks';

export interface Props {
  prevUrl?: string;
  nextUrl?: string;
  prevText?: string;
  nextText?: string;
}

const { prevUrl, nextUrl, prevText = 'Newer posts', nextText = 'Older posts' } = Astro.props;
---

{
  (prevUrl || nextUrl) && (
    <div class="container-max mx-auto px-4 sm:px-6 lg:px-8 mt-12">
      <div class="flex flex-row mx-auto max-w-4xl justify-between items-center">
        {prevUrl ? (
          <a
            href={getPermalink(prevUrl)}
            class="group inline-flex items-center justify-center px-6 py-3 text-base font-semibold rounded-lg text-charcoal dark:text-white bg-white/70 dark:bg-gray-800/70 backdrop-blur-md border border-border hover:bg-white dark:hover:bg-gray-700 hover:border-klein dark:hover:border-electric-cyan transition-all duration-300 shadow-soft hover:shadow-md hover:-translate-y-0.5"
            style="border-radius: 8px;"
          >
            <Icon name="tabler:chevron-left" class="w-5 h-5 mr-2 group-hover:-translate-x-1 transition-transform" />
            <span>{prevText}</span>
          </a>
        ) : (
          <div />
        )}

        {nextUrl ? (
          <a
            href={getPermalink(nextUrl)}
            class="group inline-flex items-center justify-center px-6 py-3 text-base font-semibold rounded-lg text-white bg-klein hover:bg-blue-700 transition-all duration-300 shadow-soft hover:shadow-neon-blue hover:-translate-y-0.5"
            style="border-radius: 8px;"
          >
            <span>{nextText}</span>
            <Icon name="tabler:chevron-right" class="w-5 h-5 ml-2 group-hover:translate-x-1 transition-transform" />
          </a>
        ) : (
          <div />
        )}
      </div>
    </div>
  )
}
