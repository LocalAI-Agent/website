---
import { getPermalink } from '~/utils/permalinks';

import { APP_BLOG } from 'astrowind:config';
import type { Post } from '~/types';

export interface Props {
  tags: Post['tags'];
  class?: string;
  title?: string | undefined;
  isCategory?: boolean;
}

const { tags, class: className = 'flex flex-wrap gap-2', title = undefined, isCategory = false } = Astro.props;
---

{
  tags && Array.isArray(tags) && (
    <>
      {title !== undefined && <span class="align-super font-normal text-secondary dark:text-gray-400">{title}</span>}
      <ul class={className}>
        {tags.map((tag) => (
          <li class="inline-block mb-2">
            {!APP_BLOG?.tag?.isEnabled ? (
              <span
                class="px-3 py-1 text-sm bg-klein/10 dark:bg-electric-cyan/10 text-klein dark:text-electric-cyan rounded-full border border-klein/20 dark:border-electric-cyan/20 hover:bg-klein/20 dark:hover:bg-electric-cyan/20 transition-colors cursor-pointer lowercase font-medium"
                style="border-radius: 8px;"
              >
                {tag.title}
              </span>
            ) : (
              <a
                href={getPermalink(tag.slug, isCategory ? 'category' : 'tag')}
                class="px-3 py-1 text-sm bg-klein/10 dark:bg-electric-cyan/10 text-klein dark:text-electric-cyan rounded-full border border-klein/20 dark:border-electric-cyan/20 hover:bg-klein/20 dark:hover:bg-electric-cyan/20 transition-colors lowercase font-medium inline-block"
                style="border-radius: 8px;"
              >
                {tag.title}
              </a>
            )}
          </li>
        ))}
      </ul>
    </>
  )
}
